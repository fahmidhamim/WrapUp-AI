APP_NAME=WrapUp AI Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:8082
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_SECONDS=0.25
JOB_RETRY_BACKOFF_SECONDS=5.0
MAX_JOB_RETRIES=3
HTTP_TIMEOUT_SECONDS=60.0

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_OPTIONAL_JWT_SECRET

DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY

# Hybrid speaker diarization via pyannote.audio
# Get a free HuggingFace token at https://hf.co/settings/tokens
# then accept the model terms at https://hf.co/pyannote/speaker-diarization-3.1
# Leave empty to fall back to Deepgram's built-in diarization.
PYANNOTE_AUTH_TOKEN=
DIARIZATION_ENABLED=true
DIARIZATION_MIN_SPEAKERS=1
DIARIZATION_MAX_SPEAKERS=20
DIARIZATION_MERGE_GAP=0.5
DIARIZATION_MIN_SEGMENT_DURATION=0.3

# Whisper fallback transcription (faster-whisper, runs locally — no API key needed)
# Runs when Deepgram word confidence < WHISPER_CONFIDENCE_THRESHOLD
WHISPER_FALLBACK_ENABLED=true
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_CONFIDENCE_THRESHOLD=0.80

# Audio preprocessing before Whisper (normalise, silence trim, noise reduction)
AUDIO_PREPROCESSING_ENABLED=true

GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL_SUMMARY=llama-3.3-70b-versatile
GROQ_MODEL_CHAT=llama-3.1-8b-instant
ENABLE_TRANSFORMER_EMBEDDINGS=false
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_PLUS=price_xxx_plus
STRIPE_PRICE_BUSINESS=price_xxx_business

DATA_DIR=backend/data
FAISS_DIR_NAME=faiss
SUMMARY_TEMPERATURE=0.2
CHAT_TEMPERATURE=0.1
